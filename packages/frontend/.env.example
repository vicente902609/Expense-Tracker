# Copy this file to `.env` in this same directory: packages/frontend/.env
# Vite exposes only variables prefixed with VITE_.

# API root (no trailing slash). Paths are appended: /auth/login, /expenses, /categories, …
#
# Serverless (AWS): use your HTTP API invoke URL, often including stage, e.g.:
#   https://xxxxxxxx.execute-api.us-east-1.amazonaws.com/dev
#
# Local Express: same path layout is mounted at the server root, e.g.:
#   http://localhost:4000
# Legacy (still supported): http://localhost:4000/api/v1
VITE_API_BASE_URL=http://localhost:4000
