# ──────────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────────
# Secret used to sign access tokens (15-minute lifetime).
# Must be a random string of at least 32 characters.
JWT_SECRET=replace-with-a-random-32-char-secret

# Secret used to sign refresh tokens (7-day lifetime).
# Must be different from JWT_SECRET.
REFRESH_TOKEN_SECRET=replace-with-another-random-32-char-secret

# ──────────────────────────────────────────────────────────────
# AWS / DynamoDB
# ──────────────────────────────────────────────────────────────
# AWS region where the DynamoDB table is deployed.
AWS_REGION=us-east-1

# DynamoDB table name. Defaults to "expense-tracker-dev" when not set.
# The Serverless deployment sets this automatically to expense-tracker-<stage>.
TABLE_NAME=expense-tracker-dev

# ──────────────────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────────────────
# API key for OpenAI. Required for AI-powered expense parsing and goal insights.
# Leave empty to disable AI features.
OPENAI_API_KEY=

# OpenAI model to use (e.g. gpt-4o, gpt-4o-mini).
# Leave empty to disable AI features.
OPENAI_MODEL=gpt-4o
