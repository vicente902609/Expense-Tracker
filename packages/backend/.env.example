# Copy this file to `.env` in this same directory: packages/backend/.env
# The server loads packages/backend/.env and the repo root .env (via dotenv).

NODE_ENV=development
# HTTP port for the API
PORT=4000
# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017
# Database name
MONGODB_DB_NAME=expense_tracker
# JWT signing secret — must be at least 16 characters (validated at startup)
JWT_SECRET=replace-with-a-long-secret-at-least-16-chars
# Refresh token signing (separate from access token; min 16 characters)
REFRESH_TOKEN_SECRET=replace-with-another-long-secret-at-least-16-chars
# Allowed browser origin for CORS (Vite dev, or your deployed frontend URL when the API is local or tunneled)
CLIENT_ORIGIN=http://localhost:3000
# Optional: enables POST /ai/parse-expense with OpenAI. If unset, that route returns a friendly error.
OPENAI_API_KEY=
# Model id for the OpenAI Responses API
OPENAI_MODEL=gpt-4.1-mini
